<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#F6F8FB">

    <TextView
        android:id="@+id/widget_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Habit Tracker"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#0F172A" />

    <ListView
        android:id="@+id/widget_habit_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:dividerHeight="6dp"
        android:transcriptMode="disabled" />

    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No habits available"
        android:textSize="13sp"
        android:textColor="#334155"
        android:paddingTop="8dp"
        android:visibility="gone" />

</LinearLayout>
