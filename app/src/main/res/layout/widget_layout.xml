<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F6F8FB">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Habit Tracker"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="#1C2434" />

    <TextView
        android:id="@+id/widget_habit_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Habit name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0A1020" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Not completed today"
        android:textSize="13sp"
        android:textColor="#334155" />

    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Streak: 0"
        android:textSize="13sp"
        android:textColor="#334155" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_complete_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mark Complete"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:minHeight="0dp"
            android:padding="8dp" />

        <Button
            android:id="@+id/widget_next_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Next"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:minHeight="0dp"
            android:padding="8dp" />
    </LinearLayout>

</LinearLayout>
