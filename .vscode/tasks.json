{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Android: Assemble Debug",
			"type": "shell",
			"command": "./gradlew",
			"args": [
				"assembleDebug"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Android: Check Device",
			"type": "shell",
			"command": "bash",
			"args": [
				"./scripts/check-adb-device.sh"
			],
			"problemMatcher": []
		},
		{
			"label": "Android: Install Debug",
			"type": "shell",
			"command": "./gradlew",
			"args": [
				"installDebug"
			],
			"dependsOn": [
				"Android: Check Device"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Android: Launch App",
			"type": "shell",
			"command": "adb",
			"args": [
				"shell",
				"am",
				"start",
				"-n",
				"com.example.habittracker/.MainActivity"
			],
			"dependsOn": [
				"Android: Install Debug"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Android: Install + Launch",
			"type": "shell",
			"command": "echo",
			"args": [
				"App install and launch completed."
			],
			"dependsOn": [
				"Android: Launch App"
			],
			"dependsOrder": "sequence",
			"problemMatcher": []
		}
	]
}